{
  "name": "seongrim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "start-prerender": "serve -s dist"
  },
  "reactSnap": {
    "include": [
      "/",
      "/welcome/greetings",
      "/welcome/new-family",
      "/welcome/service-times",
      "/welcome/directions",
      "/about/vision",
      "/about/staff",
      "/about/history",
      "/sermons/sunday",
      "/sermons/sunday-afternoon",
      "/sermons/wednesday",
      "/sermons/dawn",
      "/sermons/choir",
      "/sermons/special-praise",
      "/education/toddler",
      "/education/elementary",
      "/education/youth",
      "/education/young-adult",
      "/news/church-news",
      "/news/bulletin",
      "/news/album",
      "/news/free-board"
    ],
    "puppeteer": {
      "headless": "new"
    },
    "skipThirdPartyRequests": true,
    "fixWebpackChunks": false,
    "startServer": "npm run start-prerender",
    "buildPath": "dist",
    "source": "dist"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "framer-motion": "^12.23.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.7.1",
    "yet-another-react-lightbox": "^3.25.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.30.1",
    "@storybook/addon-a11y": "^9.1.4",
    "@storybook/addon-docs": "^9.1.4",
    "@storybook/addon-onboarding": "^9.1.4",
    "@storybook/addon-vitest": "^9.1.4",
    "@storybook/react-vite": "^9.1.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.4",
    "globals": "^16.3.0",
    "playwright": "^1.55.0",
    "prop-types": "^15.8.1",
    "react-snap": "^1.23.0",
    "serve": "^14.2.5",
    "storybook": "^9.1.4",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
